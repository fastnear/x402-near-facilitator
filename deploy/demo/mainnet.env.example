# /etc/x402-demo/mainnet.env — mode 0640 root:x402-demo-mainnet.
# The API key file itself must be mode 0600, owned by x402-demo-mainnet.
FACILITATOR_URL=https://x402.mikedotexe.com
FACILITATOR_API_KEY_FILE=/etc/x402-demo/credentials/mainnet/api-key
NETWORK=near:mainnet
# The exact Circle USDC token account the facilitator client is
# allowlisted for.
ASSET=<mainnet-usdc-token-account>
PAY_TO=count.mike.near
AMOUNT=1000
PORT=4022
