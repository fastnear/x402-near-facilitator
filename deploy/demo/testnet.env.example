# /etc/x402-demo/testnet.env — mode 0640 root:x402-demo-testnet.
# The API key file itself must be mode 0600, owned by x402-demo-testnet.
FACILITATOR_URL=https://test.x402.mikedotexe.com
FACILITATOR_API_KEY_FILE=/etc/x402-demo/credentials/testnet/api-key
NETWORK=near:testnet
# The exact Circle test-USDC token account the facilitator client is
# allowlisted for.
ASSET=<testnet-usdc-token-account>
PAY_TO=merchant.mike.testnet
AMOUNT=1000
PORT=4021
