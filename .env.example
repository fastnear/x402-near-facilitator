# Local development only. Production uses JSON config plus systemd credentials.
# Never put funded mainnet keys or production service credentials in this file.

# Pass the non-secret config explicitly:
# x402-near-facilitator --config deploy/config/testnet.json.example

# Use *_FILE variables so secrets do not appear in process listings or tracked
# configuration. Each file must contain only the value and be mode 0600.
DATABASE_URL_FILE=/absolute/path/to/local/database-url
DATABASE_DIRECT_URL_FILE=/absolute/path/to/local/direct-database-url
RELAYER_KEY_FILE=/absolute/path/to/unfunded-or-testnet-relayer-key
API_KEY_PEPPER_FILE=/absolute/path/to/local-api-key-pepper

# Optional locally. Required before the production observability gate closes.
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS_FILE=/absolute/path/to/local-otel-headers
OTEL_SERVICE_NAME=x402-near-facilitator
RUST_LOG=x402_near_facilitator=info,x402_chain_near=info,tower_http=info
